# =============================================================================
# Secrets — never commit
# =============================================================================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.env
!.env.example          # the template is fine to track
.pipeline_key          # software-root passphrase file
*.key
*.pem
!tests/fixtures/*.pem  # test-only fixtures (verified fake)
service-account*.json
*service_account*.json
!tests/fixtures/*service_account*.json  # test-only fixture (verified fake)
credentials.json
secrets.json
*.gcp-credentials.json
# OAuth 2.0 client secrets downloaded from Google Cloud Console
client_secret*.json
client-secret*.json
*.apps.googleusercontent.com.json
*.apps.googleusercontent.com.txt

