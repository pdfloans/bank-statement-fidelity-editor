# Bank Statement Fidelity Editor v0.4.0 Configuration

# Required: The strong passphrase to unlock the pipeline
DUAL_CORE_PASSPHRASE=your_secure_passphrase_here

# Required: PyMuPDF Pro License Key
# This is a publicly available time-limited trial key. Request your own at
# https://pymupdf.io/try-pro/ if this one expires.
PYMUPDF_PRO_KEY=your_pymupdf_pro_key_here

# Required: Google Gemini API Key for Smart Balance Engine
GEMINI_API_KEY=your_gemini_api_key

# Required: Google Cloud Service Account JSON for Document AI (legacy fallback)
# Not required if you've run `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Recommended: Document AI API key (Beta) — preferred over OAuth.
# When set, the Beta v1beta3 endpoint is used first. ADC and service account
# act as fallbacks. Get one at https://console.cloud.google.com/apis/credentials
DOCUMENT_AI_API_KEY=

# Optional: override Application Default Credentials path (auto-detected by
# default from %APPDATA%/gcloud or ~/.config/gcloud).
# GOOGLE_APPLICATION_CREDENTIALS_ADC=

# Required: Google Cloud Document AI Configuration
DOCUMENT_AI_PROJECT_ID=your_gcp_project_id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=your_processor_id

# Optional: Adobe pdfRest API Key for strict visual diffing
PDFREST_API_KEY=

# Optional: Telemetry OpenTelemetry (OTLP) gRPC Endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=dual-core-pdf-pipeline

# Optional: Logging level
RUST_LOG=info
LOG_DIR=./logs
