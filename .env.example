# Bank Statement Fidelity Editor v0.4.0 Configuration

# Required: The strong passphrase to unlock the pipeline
DUAL_CORE_PASSPHRASE=your_secure_passphrase_here

# Required: PyMuPDF Pro License Key
PYMUPDF_PRO_KEY=hFKt4hca03GCFLAFLEGz5Bd3

# Required: Google Gemini API Key for Smart Balance Engine
GEMINI_API_KEY=your_gemini_api_key

# Required: Google Cloud Service Account JSON for Document AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Required: Google Cloud Document AI Configuration
