# Bank Statement Fidelity Editor v0.5.0 Configuration
# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit it.
# When packaging a macOS .app bundle, this file may be copied into
# Contents/Resources/.env so the app can load runtime configuration when
# launched from Finder.

# =============================================================================
# SECURITY (Required)
# =============================================================================
# Strong passphrase to unlock the pipeline
DUAL_CORE_PASSPHRASE=your_secure_passphrase_here

# =============================================================================
# PDF ENGINE
# =============================================================================
# PyMuPDF Pro License Key (trial keys at https://pymupdf.io/try-pro/)
PYMUPDF_PRO_KEY=your_pymupdf_pro_key_here

# =============================================================================
# LOCAL OCR (Optional — requires `--features ocr`)
# =============================================================================
# To enable Local OCR (ocrs), you need TWO things:
#   1. Build with:  cargo build --features ocr
#   2. Download ONNX model files into the models/ directory:
#      - models/text-detection.rten   (from https://ocrs-models.s3-accelerate.amazonaws.com/text-detection.rten)
#      - models/text-recognition.rten (from https://ocrs-models.s3-accelerate.amazonaws.com/text-recognition.rten)
# Without both files, the UI will show "Local OCR ⛔ Unavailable".

# =============================================================================
# AI PROVIDER — Gemini
# =============================================================================
# Google Gemini API Key (get at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Auth mode: "api_key" (default) or "vertex" (enterprise, uses SA/ADC)
GEMINI_AUTH_MODE=api_key

# Groq API Key (get at https://console.groq.com/keys)
GROQ_API_KEY=

# OpenRouter API Key (get at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Which AI provider to use for balance analysis, vision, and completeness checks.
# Accepted values (case-insensitive):
#   manual_only   — No AI (default)
#   gemini_api_key / gemini — Google Gemini via API key
#   gemini_vertex  / vertex — Google Gemini via Vertex AI
#   groq_api_key   / groq   — Groq (fast Llama 3)
#   openrouter_api_key / openrouter — OpenRouter (DeepSeek)
# This is also persisted by the GUI's Backend Preferences panel.
AI_PROVIDER=manual_only

# =============================================================================
# DOCUMENT PARSERS
# =============================================================================

# --- Mindee (DEFAULT parser) ---
# Financial Document API key (get at https://platform.mindee.com/)
MINDEE_API_KEY=

# --- LlamaParse (LLM-based parser) ---
# API key (get at https://cloud.llamaindex.ai/)
LLAMAPARSE_API_KEY=

# --- Google Document AI ---
DOCUMENT_AI_PROJECT_ID=your_gcp_project_id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=your_processor_id

# Auth: Service account JSON path. Not needed if you ran
# `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Document AI API key (Beta v1beta3 endpoint). ADC/SA act as fallbacks.
# Get at https://console.cloud.google.com/apis/credentials
DOCUMENT_AI_API_KEY=

# =============================================================================
# VERIFICATION
# =============================================================================

# pdfRest — Adobe-tier cloud PDF rendering for visual diff
# Get at https://pdfrest.com/ → Dashboard → API Keys
PDFREST_API_KEY=

# Applitools Eyes — Visual AI testing (optional additive layer)
# Get at https://eyes.applitools.com/ → Profile → My API Key
APPLITOOLS_API_KEY=

# =============================================================================
# TELEMETRY & LOGGING (Optional)
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=dual-core-pdf-pipeline
RUST_LOG=info
LOG_DIR=./logs
